<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Shared by cef_host (browser) and all CEF helper processes. The renderer
       and GPU helpers JIT JavaScript / WebAssembly, so they need JIT + unsigned
       executable memory under hardened runtime. Library validation is relaxed
       because the framework is loaded by dlopen; when everything is signed with
       one identity it would pass anyway, but this keeps ad-hoc/dev builds
       working too. get-task-allow is for local debugging; the signed-release
       build drops it automatically by using entitlements.release.plist instead
       (selected when CEF_HOST_ADHOC=OFF). -->
  <key>com.apple.security.cs.allow-jit</key><true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
  <key>com.apple.security.cs.disable-library-validation</key><true/>
  <key>com.apple.security.get-task-allow</key><true/>
  <!-- Hardened-runtime device access (same set Chrome's helpers carry). Without
       these, a hardened-runtime process is KILLED the instant a page touches the
       hardware — even with the usage string in the host app's Info.plist — which
       is exactly what Google sign-in's WebAuthn/FIDO Bluetooth probe triggers.
       With them, the access prompts (and is denied-safe) instead of crashing. -->
  <key>com.apple.security.device.bluetooth</key><true/>
  <key>com.apple.security.device.camera</key><true/>
  <key>com.apple.security.device.audio-input</key><true/>
</dict>
</plist>
