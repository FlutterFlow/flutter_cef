<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key><string>cef_host</string>
  <key>CFBundleIdentifier</key><string>dev.flutter_cef.cef_host</string>
  <key>CFBundleName</key><string>cef_host</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleInfoDictionaryVersion</key><string>6.0</string>
  <key>CFBundleVersion</key><string>1</string>
  <key>CFBundleShortVersionString</key><string>1.0</string>
  <key>LSMinimumSystemVersion</key><string>12.0</string>
  <key>NSHighResolutionCapable</key><true/>
  <!-- Agent process: no Dock icon, no menu bar. -->
  <key>LSUIElement</key><true/>
  <!-- Privacy usage descriptions: like any real browser, the embedded Chromium
       can touch TCC-gated hardware on behalf of the web page. macOS SIGABRTs the
       process the instant it accesses one of these WITHOUT a usage string (e.g.
       Google sign-in probing WebAuthn/FIDO security keys reaches CoreBluetooth
       for BLE/hybrid passkeys). These strings let the access prompt instead of
       crash; deny is safe (the feature just fails and the page falls back). -->
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>A web page is requesting Bluetooth to use a security key or passkey.</string>
  <key>NSCameraUsageDescription</key>
  <string>A web page is requesting camera access.</string>
  <key>NSMicrophoneUsageDescription</key>
  <string>A web page is requesting microphone access.</string>
</dict>
</plist>
