<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Signed-release entitlements for cef_host (browser) + all CEF helper
       processes. Identical to entitlements.plist EXCEPT it omits
       get-task-allow: that entitlement makes notarization hard-fail and is a
       local task-port privilege-escalation vector, so a distributable build
       must not carry it. Selected automatically by the build when
       CEF_HOST_ADHOC=OFF (see CMakeLists.txt / build_cef_host.sh).
       The renderer and GPU helpers JIT JavaScript / WebAssembly, so they still
       need JIT + unsigned executable memory under hardened runtime; library
       validation stays relaxed because the framework is loaded via dlopen. -->
  <key>com.apple.security.cs.allow-jit</key><true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
  <key>com.apple.security.cs.disable-library-validation</key><true/>
</dict>
</plist>
